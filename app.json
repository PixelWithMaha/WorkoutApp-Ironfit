{
  "expo": {
    "name": "Wironfit-app",
    "slug": "ironfit-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMotionUsageDescription": "This app uses the pedometer to track your daily steps."
      },
      "bundleIdentifier": "com.ironfit.app"
    },
    "android": {
      "package": "com.ironfit.app",
      "minSdkVersion": 26,
      "permissions": [
        "ACTIVITY_RECOGNITION",
        "android.permission.health.READ_STEPS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-health-connect",
        {
          "permissions": [
            "READ_STEPS"
          ]
        }
      ]
    ]
  }
}
